---
import BaseLayout from "../../layouts/BaseLayout.astro";
import changelogConfig from "virtual:garden-changelog-config";
import { getGitLog, groupChangesByDate, getFileDiff, type CommitEntry } from "./lib/git";
import { pathToSlug, extractTitle, formatDate } from "./lib/utils";
import { formatDiff } from "./lib/diff-formatter";

const { contentDir, diffLines, historyDays } = changelogConfig;
const base = import.meta.env.BASE_URL;
const changes = getGitLog(contentDir, historyDays);
const changelog = groupChangesByDate(changes);

const hrefFor = (path: string) => `${base.replace(/\/$/, "")}/${pathToSlug(path, contentDir)}`.replace(/\/$/, "") || "/";

const fileCountLabel = (count: number, action: string) => `${count} ${count === 1 ? "file" : "files"} ${action}`;

function commitSummary(commit: CommitEntry) {
  return [
    commit.added.length > 0 && fileCountLabel(commit.added.length, "added"),
    commit.modified.length > 0 && fileCountLabel(commit.modified.length, "updated"),
    commit.renamed.length > 0 && fileCountLabel(commit.renamed.length, "moved"),
    commit.removed.length > 0 && fileCountLabel(commit.removed.length, "removed"),
  ]
    .filter(Boolean)
    .join(" · ");
}
---

<BaseLayout title="Changelog" description="Recent changes to the garden">
  <header class="content-header">
    <h1>Changelog</h1>
    <p>Recent changes to the garden.</p>
  </header>

  <div class="changelog-container">
    {
      changelog.length === 0 ? (
        <p>No recent changes found in the last {historyDays} days.</p>
      ) : (
        changelog.map((entry) => (
          <section class="changelog-entry">
            <h2 id={entry.date}>{formatDate(entry.date)}</h2>

            <div class="commit-list">
              {entry.commits.map((commit) => (
                <details class="commit-card">
                  <summary>
                    <span class="commit-summary-main">
                      <span class="commit-title">{commit.message}</span>
                    </span>
                    {commitSummary(commit) && <span class="commit-meta">{commitSummary(commit)}</span>}
                  </summary>

                  <div class="commit-body">
                    {commit.added.length > 0 && (
                      <div class="change-section added">
                        <h3>Added</h3>
                        <ul>
                          {commit.added.map((change) => (
                            <li>
                              <a href={hrefFor(change.path)}>{extractTitle(change.path, contentDir)}</a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}

                    {commit.modified.length > 0 && (
                      <div class="change-section modified">
                        <h3>Updated</h3>
                        <ul>
                          {commit.modified.map((change) => {
                            const diff = getFileDiff(change.path, change.commit, diffLines);

                            return (
                              <li>
                                <a href={hrefFor(change.path)}>{extractTitle(change.path, contentDir)}</a>
                                {diff && (
                                  <details class="diff-details">
                                    <summary>Show diff</summary>
                                    {/* prettier-ignore */}
                                    <pre class="diff"><code set:html={formatDiff(diff)} /></pre>
                                  </details>
                                )}
                              </li>
                            );
                          })}
                        </ul>
                      </div>
                    )}

                    {commit.renamed.length > 0 && (
                      <div class="change-section renamed">
                        <h3>Moved / renamed</h3>
                        <ul>
                          {commit.renamed.map((change) => (
                            <li>
                              <a href={hrefFor(change.path)}>{extractTitle(change.path, contentDir)}</a>
                              {change.oldPath && (
                                <span class="path-note"> from {extractTitle(change.oldPath, contentDir)}</span>
                              )}
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}

                    {commit.removed.length > 0 && (
                      <div class="change-section removed">
                        <h3>Removed</h3>
                        <ul>
                          {commit.removed.map((change) => (
                            <li>
                              <span class="removed-title">{extractTitle(change.path, contentDir)}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>
                </details>
              ))}
            </div>
          </section>
        ))
      )
    }
  </div>

  <style>
    .changelog-container {
      max-width: 100%;
    }

    .changelog-entry {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--color-border);
    }

    .changelog-entry:last-child {
      border-bottom: none;
    }

    .changelog-entry h2 {
      color: var(--color-text);
      margin-bottom: 1rem;
    }

    .commit-list {
      display: grid;
      gap: 0.875rem;
    }

    .commit-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 0.75rem;
      overflow: hidden;
    }

    .commit-card > summary {
      align-items: center;
      cursor: pointer;
      display: grid;
      gap: 0.35rem 0.5rem;
      grid-template-columns: 1rem 1fr;
      list-style: none;
      padding: 0.875rem 1rem;
      user-select: none;
    }

    .commit-card > summary::-webkit-details-marker {
      display: none;
    }

    .commit-card > summary::before {
      align-self: center;
      color: var(--color-muted);
      content: "›";
      font-size: 1.15rem;
      line-height: 1;
      transform-origin: center;
      transition:
        color 120ms ease,
        transform 120ms ease;
    }

    .commit-card[open] > summary::before {
      transform: rotate(90deg);
    }

    .commit-card > summary:hover::before,
    .commit-card > summary:hover .commit-title {
      color: var(--color-accent);
    }

    .commit-summary-main {
      align-items: center;
      display: flex;
      grid-column: 2;
    }

    .commit-title {
      color: var(--color-text);
      font-weight: 650;
      transition: color 120ms ease;
    }

    .commit-meta {
      color: var(--color-muted);
      font-size: 0.85rem;
      grid-column: 2;
    }

    .commit-body {
      border-top: 1px solid var(--color-border);
      min-width: 0;
      padding: 0.25rem 1rem 1rem;
    }

    .change-section {
      margin-top: 1rem;
    }

    .change-section h3 {
      font-size: 0.95rem;
      margin-bottom: 0.5rem;
    }

    .change-section.added h3 {
      color: var(--color-green);
    }

    .change-section.modified h3 {
      color: var(--color-blue);
    }

    .change-section.renamed h3 {
      color: var(--color-purple);
    }

    .change-section.removed h3 {
      color: var(--color-red);
    }

    .change-section ul {
      display: grid;
      gap: 0.5rem;
      list-style: none;
      padding-left: 0;
    }

    .change-section li {
      background: var(--color-surface-raised);
      border-radius: 0.5rem;
      min-width: 0;
      padding: 0.65rem 0.75rem;
    }

    .change-section a {
      color: var(--color-text);
      font-weight: 600;
      text-decoration: none;
    }

    .change-section a:hover {
      text-decoration: underline;
    }

    .path-note {
      color: var(--color-muted);
      font-size: 0.9rem;
    }

    .removed-title {
      color: var(--color-muted);
      font-weight: 600;
      text-decoration: line-through;
    }

    .diff-details {
      margin-top: 0.75rem;
    }

    .diff-details > summary {
      align-items: center;
      color: var(--color-accent);
      cursor: pointer;
      display: inline-flex;
      font-size: 0.9rem;
      gap: 0.25rem;
      list-style: none;
      padding: 0;
      user-select: none;
    }

    .diff-details > summary::-webkit-details-marker {
      display: none;
    }

    .diff-details > summary::before {
      content: "›";
      line-height: 1;
      transform-origin: center;
      transition: transform 120ms ease;
    }

    .diff-details[open] > summary::before {
      transform: rotate(90deg);
    }

    .diff-details > summary:hover {
      text-decoration: underline;
    }

    .diff {
      background: var(--color-code-bg);
      border-radius: 0.375rem;
      box-sizing: border-box;
      font-size: 0.85rem;
      line-height: 1.2;
      margin-top: 0.5rem;
      max-width: 100%;
      overflow-x: auto;
      padding: 1rem 1.25rem;
    }

    .diff code {
      color: var(--color-text);
      display: block;
      min-width: max-content;
      padding-right: 1rem;
    }

    .diff :global(.diff-add) {
      background: rgba(46, 160, 67, 0.15);
      color: var(--color-green);
      display: inline-block;
      width: 100%;
    }

    .diff :global(.diff-remove) {
      background: rgba(248, 81, 73, 0.15);
      color: var(--color-red);
      display: inline-block;
      width: 100%;
    }

    .diff :global(.diff-file) {
      color: var(--color-text);
      display: inline-block;
      font-weight: 600;
      width: 100%;
    }

    .diff :global(.diff-hunk) {
      color: var(--color-blue);
      display: inline-block;
      width: 100%;
    }

    .diff :global(.diff-context) {
      color: var(--color-muted);
      display: inline-block;
      width: 100%;
    }
  </style>
</BaseLayout>
