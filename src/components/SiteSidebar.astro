---
import { getCollection } from "astro:content";
import SidebarTree from "$components/SidebarTree.svelte";
import { buildSidebarTree } from "../lib/content/tree";

type Props = { base: string; currentPath: string };

const { base, currentPath } = Astro.props;
const entries = await getCollection("docs");
const tree = buildSidebarTree(entries);
---

<aside class="site-sidebar" aria-label="Garden navigation">
  <nav aria-label="Content tree">
    <SidebarTree base={base} currentPath={currentPath} nodes={tree} client:load />
  </nav>
</aside>

<style>
  .site-sidebar {
    border-right: 1px solid var(--color-border);
    height: 100%;
    overflow: auto;
    padding: 1.25rem clamp(1rem, 2vw, 1.5rem);
  }

  @media (max-width: 860px) {
    .site-sidebar {
      border-bottom: 1px solid var(--color-border);
      border-right: 0;
      height: auto;
      max-height: 18rem;
    }
  }
</style>
