---
import { getCollection } from "astro:content";
import SidebarTreeNode from "./SidebarTreeNode.astro";
import { buildSidebarTree } from "../lib/content/tree";

type Props = { base: string; currentPath: string; pagefindBundlePath: string };

const { base, currentPath, pagefindBundlePath } = Astro.props;
const entries = await getCollection("docs");
const tree = buildSidebarTree(entries);
---

<aside class="site-sidebar" aria-label="Garden navigation">
  <div class="site-search">
    <pagefind-config bundle-path={pagefindBundlePath}></pagefind-config>
    <pagefind-searchbox placeholder="Search"></pagefind-searchbox>
  </div>

  <nav aria-label="Content tree">
    <ul class="nav-tree">
      {tree.map((node) => <SidebarTreeNode base={base} currentPath={currentPath} node={node} />)}
    </ul>
  </nav>
</aside>

<style>
  .site-sidebar {
    border-right: 1px solid var(--color-border);
    height: calc(100vh - 4rem);
    overflow: auto;
    padding: 1.25rem clamp(1rem, 2vw, 1.5rem);
    position: sticky;
    top: 4rem;
  }

  .site-search {
    margin-bottom: 1.25rem;
  }

  .site-search pagefind-searchbox {
    --pagefind-ui-scale: 0.78;
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: var(--font-body);
  }

  .nav-tree {
    display: grid;
    gap: 0.12rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (max-width: 860px) {
    .site-sidebar {
      border-bottom: 1px solid var(--color-border);
      border-right: 0;
      height: auto;
      max-height: 18rem;
      position: static;
    }
  }
</style>
