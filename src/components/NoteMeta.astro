---
import { formatDate } from "$lib/content/dates";
import { tagSlug, tagsForDoc } from "$lib/tags";
import type { DocEntry } from "$lib/content/tree";
import { hrefFor } from "$lib/utils/path";

type Props = { entry: DocEntry; updated: Date; base: string };

const { entry, updated, base } = Astro.props;
const tags = tagsForDoc(entry);
---

<div class="note-meta">
  <span>
    Last Updated: <time datetime={updated.toISOString()}>{formatDate(updated)}</time>
  </span>
  <div class="note-meta__tags">
    {tags.map((tag) => <a href={hrefFor(base, `/tags/${tagSlug(tag)}/`)}>{tag}</a>)}
  </div>
</div>

<style>
  .note-meta {
    display: flex;
    flex-direction: column;
    color: var(--color-muted);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    gap: 0.35rem;
    line-height: 1.4;
    margin: 0.18rem 0 0;
  }

  .note-meta time,
  .note-meta a {
    color: inherit;
  }

  .note-meta a {
    background: var(--eldritch-tag-bg);
    border: 1px solid var(--eldritch-tag-bg);
    border-radius: 0.3rem;
    color: var(--eldritch-tag-fg);
    padding: 0.08rem 0.35rem;
    text-decoration: none;
  }

  .note-meta a:hover,
  .note-meta a:focus-visible {
    background: var(--eldritch-tag-bg-hover);
    color: var(--color-bg);
  }

  .note-meta a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .note-meta__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
