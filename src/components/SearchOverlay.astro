---
import { hrefFor } from "$lib/utils/path";

type Props = { base: string };

const { base } = Astro.props;
const contentIndexPath = hrefFor(base, "/content-index.json");
const pagefindBundlePath = hrefFor(base, "/pagefind/");
---

<div
  class="search-overlay"
  style="flex: 1;  width: 100%; padding: 0 1rem;"
  data-search-overlay
  data-base={base}
  data-content-index={contentIndexPath}
  data-pagefind-bundle={pagefindBundlePath}>
  <button class="search-trigger" type="button" data-search-open aria-haspopup="dialog">
    <span class="search-trigger__icon" aria-hidden="true"></span>
    <span class="search-trigger__label">Search notes</span>
    <kbd>/</kbd>
  </button>

  <dialog class="search-dialog" data-search-dialog aria-label="Search notes">
    <div class="search-panel" data-search-panel>
      <div class="search-input-wrap">
        <span class="search-input-icon" aria-hidden="true"></span>
        <input data-search-input type="search" placeholder="Search notes" autocomplete="off" />
        <button class="search-close" type="button" data-search-close aria-label="Close search">Esc</button>
      </div>

      <p class="search-status" data-search-status>Recent notes</p>
      <div class="search-results" data-search-results role="list"></div>
    </div>
  </dialog>
</div>

<script src="./controllers/overlay.ts"></script>

<style>
  .search-trigger {
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-muted);
    cursor: pointer;
    display: flex;
    font: inherit;
    gap: 0.55rem;
    height: 2.25rem;
    min-width: min(18rem, 36vw);
    padding: 0 0.55rem;
    text-align: left;
    flex: 1;
    width: 100%;
  }

  .search-trigger:hover,
  .search-trigger:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .search-trigger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .search-trigger__icon,
  .search-input-icon {
    border: 2px solid currentColor;
    border-radius: 999px;
    flex: 0 0 auto;
    height: 0.78rem;
    position: relative;
    width: 0.78rem;
  }

  .search-trigger__icon::after,
  .search-input-icon::after {
    background: currentColor;
    content: "";
    height: 2px;
    position: absolute;
    right: -0.34rem;
    top: 0.58rem;
    transform: rotate(45deg);
    width: 0.45rem;
  }

  .search-trigger__label {
    flex: 1 1 auto;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-trigger kbd {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
    padding: 0.18rem 0.35rem;
  }

  .search-dialog {
    background: transparent;
    border: 0;
    color: var(--color-text);
    margin: 0 auto;
    max-height: min(42rem, calc(100dvh - 4rem));
    max-width: min(42rem, calc(100vw - 2rem));
    padding: 0;
    top: 4.5rem;
    width: 100%;
  }

  .search-dialog::backdrop {
    background: color-mix(in srgb, var(--color-bg) 72%, transparent);
  }

  .search-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: 0 1.25rem 4rem rgba(0, 0, 0, 0.28);
    overflow: hidden;
  }

  .search-input-wrap {
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    gap: 0.8rem;
    padding: 0.8rem 1rem;
  }

  .search-input-wrap input {
    background: transparent;
    border: 0;
    color: var(--color-text);
    flex: 1 1 auto;
    font: inherit;
    font-size: 1rem;
    min-width: 0;
    outline: 0;
  }

  .search-input-wrap input::placeholder {
    color: var(--color-muted);
  }

  .search-close {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.22rem 0.45rem;
  }

  .search-status {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    margin: 0;
    padding: 0.75rem 1rem 0.25rem;
  }

  .search-results {
    display: flex;
    flex-direction: column;
    max-height: min(32rem, calc(100dvh - 12rem));
    overflow: auto;
    padding: 0.35rem;
  }

  :global(.search-result) {
    border-radius: 6px;
    color: var(--color-text);
    display: grid;
    gap: 0.18rem;
    padding: 0.65rem;
    text-decoration: none;
  }

  :global(.search-result:hover),
  :global(.search-result:focus-visible) {
    background: var(--color-surface-raised);
    outline: 0;
  }

  :global(.search-result__title) {
    font-weight: 650;
    line-height: 1.25;
  }

  :global(.search-result__excerpt) {
    color: var(--color-muted);
    display: -webkit-box;
    font-size: 0.86rem;
    line-height: 1.4;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  :global(.search-result__meta) {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  :global(.search-empty) {
    color: var(--color-muted);
    margin: 0;
    padding: 1rem;
  }

  @media (max-width: 860px) {
    .search-trigger {
      min-width: 100%;
      width: 100%;
    }

    .search-dialog {
      top: 1rem;
    }
  }
</style>
