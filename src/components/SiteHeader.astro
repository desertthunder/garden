---
import SearchOverlay from "$components/SearchOverlay.astro";
import { buildVersion } from "$lib/version";
import { hrefFor } from "$lib/utils/path";
type Props = { base: string; currentPath: string };
const { base, currentPath } = Astro.props;
---

<header class="site-header">
  <a class="site-title" href={hrefFor(base, "/")}>
    <span>Owais' Places</span>
    <span class="site-version" title={`Commit ${buildVersion.commit}`}>{buildVersion.display}</span>
  </a>
  <div class="site-header__actions">
    <SearchOverlay base={base} />
    <nav class="site-links" aria-label="Site links">
      <a class:list={["site-nav-link", currentPath === "/changelog" && "is-active"]} href={hrefFor(base, "/changelog/")}>
        CHANGELOG
      </a>

      <a href="https://github.com/desertthunder/garden">GitHub</a>
      <a href="https://desertthunder.dev">Dev</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    align-items: center;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    min-height: 4rem;
    padding: 0.85rem clamp(1rem, 4vw, 2rem);
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .site-title {
    align-items: center;
    color: var(--color-text);
    display: inline-flex;
    gap: 0.45rem;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-version {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 650;
    letter-spacing: 0;
  }

  .site-header__actions {
    align-items: center;
    display: flex;
    gap: 1rem;
    min-width: 0;
    flex: 1;
  }

  .site-links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    gap: 0.75rem;
    justify-content: flex-start;
  }

  .site-links a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .site-links a:hover,
  .site-nav-link.is-active {
    color: var(--color-accent);
  }

  .site-nav-link.is-active {
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  @media (max-width: 860px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      position: static;
    }

    .site-header__actions {
      align-items: stretch;
      flex-direction: column;
      width: 100%;
    }
  }
</style>
