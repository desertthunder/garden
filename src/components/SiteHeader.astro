---
import SearchOverlay from "$components/SearchOverlay.astro";
import ThemeSwitcher from "$components/ThemeSwitcher.astro";
import { buildVersion } from "$lib/version";
import { hrefFor } from "$lib/utils/path";
type Props = { base: string; currentPath: string };
const { base } = Astro.props;
---

<header class="site-header">
  <div class="site-brand">
    <a class="site-title" href={hrefFor(base, "/")}>Owais' Places</a>
    <a class="site-version" href={hrefFor(base, "/changelog/")} title={`Commit ${buildVersion.commit}`}>
      {buildVersion.display}
    </a>
  </div>
  <div class="site-header__actions">
    <SearchOverlay base={base} />
    <ThemeSwitcher />
    <nav class="site-links" aria-label="Site links">
      <a href="https://github.com/desertthunder/garden">GitHub</a>
      <a href="https://desertthunder.dev">owais</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    align-items: center;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    min-height: 4rem;
    padding: 0.85rem clamp(1rem, 4vw, 2rem);
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .site-brand {
    align-items: center;
    display: inline-flex;
    gap: 0.45rem;
    white-space: nowrap;
  }

  .site-title {
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    text-decoration: none;
  }

  .site-version {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 650;
    letter-spacing: 0;
    text-decoration: none;
  }

  .site-version:hover,
  .site-version:focus-visible {
    color: color-mix(in srgb, var(--color-accent) 88%, white);
  }

  .site-header__actions {
    align-items: center;
    display: flex;
    gap: 0.8rem;
    min-width: 0;
    flex: 1;
  }

  .site-links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    gap: 0.75rem;
    justify-content: flex-end;
    margin-left: auto;
  }

  .site-links a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .site-links a:hover,
  .site-links a:focus-visible {
    color: var(--color-accent);
  }

  @media (max-width: 860px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      position: static;
    }

    .site-header__actions {
      align-items: center;
      display: grid;
      grid-template-columns: minmax(0, auto) auto;
      justify-content: space-between;
      width: 100%;
    }

    .site-header__actions :global(.search-overlay) {
      grid-column: 1 / -1;
      padding-inline: 0 !important;
    }

    .site-links {
      justify-content: flex-end;
      margin-left: 0;
    }
  }

  @media (max-width: 520px) {
    .site-header__actions {
      column-gap: 0.65rem;
    }

    .site-links {
      gap: 0.55rem;
    }
  }
</style>
