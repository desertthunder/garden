---
import SiteHeader from "$components/SiteHeader.astro";
import SiteSidebar from "$components/SiteSidebar.astro";
import "../styles/styles.css";

type Props = { title: string; description?: string };

const { title, description = "A digital garden by desertthunder.dev" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(base, "").replace(/\/$/, "") || "/";
const ogImageUrl = new URL(`${base}/og.png`, Astro.site ?? Astro.url.origin).toString();
const hasRightRail = Astro.slots.has("right-rail");
---

<!doctype html>
<html lang="en" data-base-path={base} data-theme="cyberdream">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href={`${base}/favicon.svg`} />
    <script is:inline>
      (() => {
        const themes = new Set(["iceberg", "oxocarbon", "spaceduck", "cyberdream", "eldritch", "thorn"]);
        let theme = "cyberdream";

        try {
          const storedTheme = localStorage.getItem("garden-theme");
          if (storedTheme && themes.has(storedTheme)) {
            theme = storedTheme;
          }
        } catch {
          // If storage is blocked, keep the default theme.
        }

        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <title>{title === "Owais' Places" ? title : `${title} | Owais' Places`}</title>
  </head>
  <body>
    <SiteHeader base={base} currentPath={currentPath} />
    <div class:list={["site-shell", hasRightRail && "has-right-rail"]} data-sidebar-shell>
      <div class="sidebar-frame sidebar-frame--left">
        <button
          aria-controls="garden-map"
          aria-expanded="true"
          class="sidebar-toggle"
          data-sidebar-toggle="left"
          type="button">
          <span class="sidebar-toggle__open">Collapse map</span>
          <span class="sidebar-toggle__closed" aria-hidden="true">Map</span>
        </button>
        <SiteSidebar base={base} currentPath={currentPath} />
      </div>

      <main class="site-main">
        <article class="content" data-pagefind-body>
          <slot />
        </article>
      </main>

      {
        hasRightRail && (
          <div class="sidebar-frame sidebar-frame--right">
            <button
              aria-controls="garden-context"
              aria-expanded="true"
              class="sidebar-toggle"
              data-sidebar-toggle="right"
              type="button">
              <span class="sidebar-toggle__open">Collapse context</span>
              <span class="sidebar-toggle__closed" aria-hidden="true">
                Context
              </span>
            </button>
            <aside class="right-rail" id="garden-context" aria-label="Page context">
              <slot name="right-rail" />
            </aside>
          </div>
        )
      }
    </div>

    <script>
      const sidebarShell = document.querySelector("[data-sidebar-shell]");
      const sidebarToggles = document.querySelectorAll("[data-sidebar-toggle]");
      const sidebarTargets = { left: "garden-map", right: "garden-context" };

      function applySidebarState(side: "left" | "right", collapsed: boolean) {
        sidebarShell?.classList.toggle(`is-${side}-collapsed`, collapsed);
        document.getElementById(sidebarTargets[side])?.setAttribute("aria-hidden", String(collapsed));

        document.querySelectorAll(`[data-sidebar-toggle="${side}"]`).forEach((toggle) => {
          toggle.setAttribute("aria-expanded", String(!collapsed));
        });
      }

      for (const side of ["left", "right"] as const) {
        applySidebarState(side, localStorage.getItem(`garden-${side}-rail`) === "collapsed");
      }
      sidebarShell?.classList.add("is-sidebar-ready");

      sidebarToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          const side = toggle.getAttribute("data-sidebar-toggle");
          if (!side) return;

          const collapsed = !sidebarShell?.classList.contains(`is-${side}-collapsed`);
          applySidebarState(side as "left" | "right", collapsed);
          localStorage.setItem(`garden-${side}-rail`, collapsed ? "collapsed" : "open");
        });
      });
    </script>

    <style>
      .site-shell {
        --left-rail-width: clamp(15rem, 22vw, 20rem);
        --right-rail-width: clamp(15rem, 21vw, 19rem);
        display: grid;
        grid-template-columns: var(--left-rail-width) minmax(0, 1fr);
        height: calc(100dvh - 4rem);
        margin-inline: auto;
        max-width: 96rem;
        min-width: 0;
        overflow: hidden;
      }

      .site-shell.is-sidebar-ready {
        transition: grid-template-columns 220ms cubic-bezier(0.2, 0, 0, 1);
      }

      .site-shell.has-right-rail {
        grid-template-columns: var(--left-rail-width) minmax(0, 1fr) var(--right-rail-width);
        max-width: 112rem;
      }

      .site-shell.is-left-collapsed {
        --left-rail-width: 3rem;
      }

      .site-shell.is-right-collapsed {
        --right-rail-width: 3rem;
      }

      .site-main {
        min-width: 0;
        overflow: auto;
        padding: clamp(1.25rem, 4vw, 3rem);
      }

      .sidebar-frame {
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        min-width: 0;
        overflow: hidden;
      }

      .is-sidebar-ready .sidebar-frame {
        transition: grid-template-rows 220ms cubic-bezier(0.2, 0, 0, 1);
      }

      .sidebar-frame--left {
        border-right: 1px solid var(--color-border);
      }

      .sidebar-frame--right {
        border-left: 1px solid var(--color-border);
      }

      .sidebar-toggle {
        align-items: center;
        background: color-mix(in srgb, var(--color-bg) 88%, var(--color-surface));
        border: 0;
        border-bottom: 1px solid var(--color-border);
        color: var(--color-muted);
        cursor: pointer;
        display: flex;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        gap: 0.4rem;
        justify-content: flex-start;
        letter-spacing: 0;
        line-height: 1.2;
        min-height: 2.6rem;
        padding: 0.75rem 1rem;
        text-transform: uppercase;
        transition:
          background-color 160ms ease,
          color 160ms ease;
        width: 100%;
      }

      .sidebar-toggle:hover,
      .sidebar-toggle:focus-visible {
        color: var(--color-accent);
      }

      .sidebar-toggle:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: -2px;
      }

      .sidebar-toggle__closed {
        display: none;
      }

      .is-left-collapsed .sidebar-frame--left .sidebar-toggle,
      .is-right-collapsed .sidebar-frame--right .sidebar-toggle {
        align-items: center;
        height: 100%;
        justify-content: center;
        padding: 0.75rem 0;
        writing-mode: vertical-rl;
      }

      .is-left-collapsed .sidebar-frame--left,
      .is-right-collapsed .sidebar-frame--right {
        grid-template-rows: minmax(0, 1fr) 0fr;
      }

      .is-left-collapsed .sidebar-frame--left .sidebar-toggle__open,
      .is-right-collapsed .sidebar-frame--right .sidebar-toggle__open {
        display: none;
      }

      .is-left-collapsed .sidebar-frame--left .sidebar-toggle__closed,
      .is-right-collapsed .sidebar-frame--right .sidebar-toggle__closed {
        display: inline;
      }

      .is-sidebar-ready :global(.site-sidebar),
      .is-sidebar-ready .right-rail {
        transition:
          opacity 160ms ease,
          transform 220ms cubic-bezier(0.2, 0, 0, 1),
          visibility 0s linear 0s;
      }

      :global(.is-left-collapsed .site-sidebar) {
        opacity: 0;
        pointer-events: none;
        transform: translateX(-0.5rem);
        visibility: hidden;
      }

      .is-right-collapsed .right-rail {
        opacity: 0;
        pointer-events: none;
        transform: translateX(0.5rem);
        visibility: hidden;
      }

      .right-rail {
        height: 100%;
        min-height: 0;
        min-width: 0;
        overflow: auto;
        padding: 1.1rem clamp(1rem, 2vw, 1.5rem) 1.5rem;
      }

      @media (max-width: 860px) {
        .site-shell {
          display: block;
          height: auto;
          overflow: visible;
        }

        .sidebar-frame--left,
        .sidebar-frame--right {
          border-left: 0;
          border-right: 0;
        }

        .sidebar-frame--left {
          border-bottom: 1px solid var(--color-border);
        }

        .sidebar-frame--right {
          border-top: 1px solid var(--color-border);
        }

        .is-left-collapsed .sidebar-frame--left .sidebar-toggle,
        .is-right-collapsed .sidebar-frame--right .sidebar-toggle {
          height: auto;
          justify-content: flex-start;
          padding: 0.75rem clamp(1rem, 4vw, 1.5rem);
          writing-mode: horizontal-tb;
        }

        .is-left-collapsed .sidebar-frame--left,
        .is-right-collapsed .sidebar-frame--right {
          grid-template-rows: auto 0fr;
        }

        .right-rail {
          max-height: none;
          overflow: auto;
          padding: 1.25rem clamp(1rem, 4vw, 1.5rem);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .site-shell.is-sidebar-ready,
        .is-sidebar-ready .sidebar-frame,
        .is-sidebar-ready :global(.site-sidebar),
        .is-sidebar-ready .right-rail,
        .sidebar-toggle {
          transition-duration: 0.01ms;
        }
      }
    </style>
  </body>
</html>
