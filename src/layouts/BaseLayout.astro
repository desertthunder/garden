---
import SiteHeader from "../components/SiteHeader.astro";
import SiteSidebar from "../components/SiteSidebar.astro";
import "../styles/styles.css";

type Props = { title: string; description?: string };

const { title, description = "A digital garden by desertthunder.dev" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(base, "").replace(/\/$/, "") || "/";
const ogImageUrl = new URL(`${base}/og.png`, Astro.site ?? Astro.url.origin).toString();
const hasRightRail = Astro.slots.has("right-rail");
---

<!doctype html>
<html lang="en" data-base-path={base}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href={`${base}/favicon.svg`} />
    <title>{title === "Owais' Places" ? title : `${title} | Owais' Places`}</title>
  </head>
  <body>
    <SiteHeader base={base} currentPath={currentPath} />

    <div class:list={["site-shell", hasRightRail && "has-right-rail"]}>
      <SiteSidebar base={base} currentPath={currentPath} />
      <main class="site-main">
        <article class="content" data-pagefind-body>
          <slot />
        </article>
      </main>

      {
        hasRightRail && (
          <aside class="right-rail" aria-label="Page context">
            <slot name="right-rail" />
          </aside>
        )
      }
    </div>

    <style>
      .site-shell {
        display: grid;
        grid-template-columns: minmax(13rem, 18rem) minmax(0, 1fr);
        height: calc(100dvh - 4rem);
        margin-inline: auto;
        max-width: 90rem;
        min-width: 0;
        overflow: hidden;
      }

      .site-shell.has-right-rail {
        grid-template-columns: minmax(13rem, 18rem) minmax(0, 1fr) minmax(12rem, 16rem);
        max-width: 106rem;
      }

      .site-main {
        min-width: 0;
        overflow: auto;
        padding: clamp(1.25rem, 4vw, 3rem);
      }

      .right-rail {
        align-self: stretch;
        border-left: 1px solid var(--color-border);
        color: var(--color-muted);
        height: 100%;
        min-width: 0;
        overflow: auto;
        padding: 1rem 2rem;
      }

      @media (max-width: 860px) {
        .site-shell {
          display: block;
          height: auto;
          overflow: visible;
        }

        .right-rail {
          border-left: 0;
          border-top: 1px solid var(--color-border);
          max-height: 70dvh;
          overflow: auto;
          padding: 1.25rem clamp(1rem, 4vw, 1.5rem);
        }
      }
    </style>
  </body>
</html>
