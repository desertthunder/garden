---
import SiteHeader from "../components/SiteHeader.astro";
import SiteSidebar from "../components/SiteSidebar.astro";
import "../styles/styles.css";

type Props = { title: string; description?: string };

const { title, description = "A digital garden by desertthunder.dev" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const pagefindBundlePath = `${base}/pagefind/`;
const currentPath = Astro.url.pathname.replace(base, "").replace(/\/$/, "") || "/";
const ogImageUrl = new URL(`${base}/og.png`, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href={`${base}/favicon.svg`} />
    <link rel="stylesheet" href={`${base}/pagefind/pagefind-component-ui.css`} />
    <script is:inline src={`${base}/pagefind/pagefind-component-ui.js`} type="module"></script>
    <title>{title === "Owais' Places" ? title : `${title} | Owais' Places`}</title>
  </head>
  <body>
    <SiteHeader base={base} currentPath={currentPath} />

    <div class="site-shell">
      <SiteSidebar base={base} currentPath={currentPath} pagefindBundlePath={pagefindBundlePath} />

      <main class="site-main">
        <article class="content" data-pagefind-body>
          <slot />
        </article>
      </main>
    </div>

    <style>
      .site-shell {
        display: grid;
        grid-template-columns: minmax(13rem, 18rem) minmax(0, 1fr);
        margin-inline: auto;
        max-width: 90rem;
      }

      .site-main {
        min-width: 0;
        padding: clamp(1.25rem, 4vw, 3rem);
      }

      @media (max-width: 860px) {
        .site-shell {
          display: block;
        }
      }
    </style>
  </body>
</html>
