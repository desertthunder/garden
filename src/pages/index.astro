---
import { getCollection, render } from "astro:content";
import NoteList from "$components/NoteList.astro";
import BaseLayout from "$layouts/BaseLayout.astro";
import { gitUpdatedDateForDoc } from "$lib/content/dates";
import { pathForDoc } from "$lib/content/paths";
import { hrefFor } from "$lib/utils/path";

const entries = await getCollection("docs");
const entry = entries.find((item) => pathForDoc(item) === "/");
if (!entry) {
  throw new Error("Missing homepage content entry: src/content/docs/index.mdx");
}

const { Content } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const notes = entries
  .filter((item) => pathForDoc(item) !== "/" && item.data.sidebar?.hidden !== true)
  .map((item) => {
    const path = pathForDoc(item);
    const section = path.split("/").filter(Boolean)[0] ?? "writing";
    const updated = gitUpdatedDateForDoc(item);

    return { item, path, section, updated };
  });

const recentNotes = [...notes]
  .sort((a, b) => b.updated.getTime() - a.updated.getTime() || a.item.data.title.localeCompare(b.item.data.title))
  .slice(0, 8);
---

<BaseLayout title="Owais' Places" description={entry.data.description}>
  <header class="home-hero">
    <p class="home-kicker">Digital garden</p>
    <h1>Owais' Places</h1>
    <p class="home-deck">Notes on software, writing, philosophy, psychology, and the odd trail that connects them.</p>
    <div class="home-actions">
      <a href={hrefFor(base, "/engineering/")}>Start with engineering</a>
      <a href={hrefFor(base, "/changelog/")}>Recent updates</a>
    </div>
  </header>

  <section class="home-intro">
    <Content />
  </section>

  <section class="home-section" aria-labelledby="notes-heading">
    <div class="home-section-header">
      <h2 id="notes-heading">Browse Notes</h2>
    </div>

    <NoteList notes={recentNotes.map(({ item, path, updated }) => ({ entry: item, path, updated }))} base={base} />
  </section>

  <style>
    .home-hero {
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 2rem;
      padding: clamp(1rem, 4vw, 2rem) 0 2rem;
    }

    .home-kicker {
      color: var(--color-accent);
      font-family: var(--font-mono);
      font-size: 0.85rem;
      margin: 0 0 0.65rem;
      text-transform: uppercase;
    }

    .home-hero h1 {
      font-family: var(--font-heading);
      font-size: clamp(3rem, 8vw, 6.5rem);
      line-height: 0.95;
      margin: 0;
    }

    .home-deck {
      color: var(--color-muted);
      font-size: clamp(1.1rem, 2vw, 1.35rem);
      max-width: 40rem;
    }

    .home-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .home-actions a {
      border: 1px solid var(--color-border);
      border-radius: 0.45rem;
      color: var(--color-text);
      padding: 0.55rem 0.75rem;
      text-decoration: none;
    }

    .home-actions a:first-child {
      background: var(--color-text);
      color: var(--color-bg);
    }

    .home-actions a:hover {
      border-color: var(--color-accent);
    }

    .home-intro {
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
    }

    .home-section {
      margin-top: 2.5rem;
    }

    .home-section-header {
      align-items: baseline;
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .home-section-header h2 {
      font-family: var(--font-heading);
      margin: 0;
    }

    .home-section-header p {
      color: var(--color-muted);
      margin: 0;
    }

    .home-grid {
      display: grid;
      gap: 0.5rem;
      grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    }

    .home-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      padding: 1rem;
    }

    .home-card h3 {
      font-family: var(--font-heading);
      margin: 0 0 0.7rem;
    }

    .home-card ul {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .home-card li + li {
      margin-top: 0.45rem;
    }

    .home-card a {
      color: var(--color-text);
      text-decoration: none;
    }

    .home-card a:hover {
      color: var(--color-accent);
    }

    @media (max-width: 860px) {
      .home-section-header {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.25rem;
      }
    }
  </style>
</BaseLayout>
