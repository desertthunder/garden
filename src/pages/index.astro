---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pathForDoc } from "../lib/content-paths";

const entries = await getCollection("docs");
const entry = entries.find((item) => pathForDoc(item) === "/");

if (!entry) {
  throw new Error("Missing homepage content entry: src/content/docs/index.mdx");
}

const { Content } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function hrefFor(path: string) {
  return `${base}${path}` || "/";
}

function sectionTitle(section: string) {
  return section
    .split(/[-_]/)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}

const notes = entries
  .filter((item) => pathForDoc(item) !== "/" && item.data.sidebar?.hidden !== true)
  .map((item) => {
    const path = pathForDoc(item);
    const section = path.split("/").filter(Boolean)[0] ?? "writing";

    return { item, path, section };
  });

const featuredSections = ["writing", "engineering", "programming", "psychology", "philosophy", "culture"]
  .map((section) => ({ section, items: notes.filter((note) => note.section === section).slice(0, 4) }))
  .filter((group) => group.items.length > 0);

const recentNotes = [...notes].sort((a, b) => a.item.id.localeCompare(b.item.id)).slice(0, 8);
---

<BaseLayout title="Owais' Places" description={entry.data.description}>
  <header class="home-hero">
    <p class="home-kicker">Digital garden</p>
    <h1>Owais' Places</h1>
    <p class="home-deck">Notes on software, writing, philosophy, psychology, and the odd trail that connects them.</p>
    <div class="home-actions">
      <a href={hrefFor("/engineering/")}>Start with engineering</a>
      <a href={hrefFor("/changelog/")}>Recent updates</a>
    </div>
  </header>

  <section class="home-intro">
    <Content />
  </section>

  <section class="home-section" aria-labelledby="paths-heading">
    <div class="home-section-header">
      <h2 id="paths-heading">Paths</h2>
    </div>

    <div class="home-grid">
      {
        featuredSections.map((group) => (
          <section class="home-card">
            <h3>{sectionTitle(group.section)}</h3>
            <ul>
              {group.items.map(({ item, path }) => (
                <li>
                  <a href={hrefFor(path)}>{item.data.title}</a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </section>

  <section class="home-section" aria-labelledby="notes-heading">
    <div class="home-section-header">
      <h2 id="notes-heading">Browse Notes</h2>
      <p>A small entry point into the larger archive.</p>
    </div>

    <ol class="home-note-list">
      {
        recentNotes.map(({ item, path, section }) => (
          <li>
            <a href={hrefFor(path)}>{item.data.title}</a>
            <span>{sectionTitle(section)}</span>
          </li>
        ))
      }
    </ol>
  </section>

  <style>
    .home-hero {
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 2rem;
      padding: clamp(1rem, 4vw, 2rem) 0 2rem;
    }

    .home-kicker {
      color: var(--color-accent);
      font-family: var(--font-mono);
      font-size: 0.85rem;
      margin: 0 0 0.65rem;
      text-transform: uppercase;
    }

    .home-hero h1 {
      font-family: var(--font-heading);
      font-size: clamp(3rem, 8vw, 6.5rem);
      line-height: 0.95;
      margin: 0;
    }

    .home-deck {
      color: var(--color-muted);
      font-size: clamp(1.1rem, 2vw, 1.35rem);
      max-width: 40rem;
    }

    .home-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }

    .home-actions a {
      border: 1px solid var(--color-border);
      border-radius: 0.45rem;
      color: var(--color-text);
      padding: 0.55rem 0.75rem;
      text-decoration: none;
    }

    .home-actions a:first-child {
      background: var(--color-text);
      color: var(--color-bg);
    }

    .home-actions a:hover {
      border-color: var(--color-accent);
    }

    .home-intro {
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
    }

    .home-section {
      margin-top: 2.5rem;
    }

    .home-section-header {
      align-items: baseline;
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .home-section-header h2 {
      font-family: var(--font-heading);
      margin: 0;
    }

    .home-section-header p {
      color: var(--color-muted);
      margin: 0;
    }

    .home-grid {
      display: grid;
      gap: 0.5rem;
      grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    }

    .home-card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      padding: 1rem;
    }

    .home-card h3 {
      font-family: var(--font-heading);
      margin: 0 0 0.7rem;
    }

    .home-card ul,
    .home-note-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .home-card li + li {
      margin-top: 0.45rem;
    }

    .home-card a,
    .home-note-list a {
      color: var(--color-text);
      text-decoration: none;
    }

    .home-card a:hover,
    .home-note-list a:hover {
      color: var(--color-accent);
    }

    .home-note-list {
      border-top: 1px solid var(--color-border);
    }

    .home-note-list li {
      align-items: baseline;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      padding: 0.75rem 0;
    }

    .home-note-list span {
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.82rem;
    }

    @media (max-width: 860px) {
      .home-section-header,
      .home-note-list li {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.25rem;
      }
    }
  </style>
</BaseLayout>
