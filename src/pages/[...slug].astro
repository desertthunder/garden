---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pathForDoc } from "../lib/content/paths";

export async function getStaticPaths() {
  const entries = await getCollection("docs");

  return entries
    .filter((entry) => pathForDoc(entry) !== "/")
    .map((entry) => {
      const slug = pathForDoc(entry).replace(/^\/|\/$/g, "");

      return { params: { slug }, props: { entry } };
    });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <header class="content-header">
    <h1>{entry.data.title}</h1>
    {entry.data.description && <p>{entry.data.description}</p>}
  </header>
  <Content />
  {
    headings.length > 0 && (
      <div slot="right-rail">
        <nav class="page-toc" aria-label="Page table of contents">
          <h2>On this page</h2>
          <ol>
            {headings
              .filter((heading) => heading.depth === 2 || heading.depth === 3)
              .map((heading) => (
                <li class={`depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
            ))}
          </ol>
        </nav>
      </div>
    )
  }
</BaseLayout>
