---
import { getCollection, render } from "astro:content";
import NoteList from "$components/NoteList.astro";
import NoteMeta from "$components/NoteMeta.astro";
import RightRailNoteList from "$components/RightRailNoteList.astro";
import RightRailSection from "$components/RightRailSection.astro";
import BaseLayout from "$layouts/BaseLayout.astro";
import {
  backlinkNotes,
  buildContentIndex,
  latestNotes,
  outboundLinkNotes,
  previewPayload,
  sameFolderNotes,
} from "$lib/content/index";
import { gitUpdatedDateForDoc } from "$lib/content/dates";
import { pathForDoc } from "$lib/content/paths";
import { folderListingForPath, folderPathsForEntries } from "$lib/content/tree";
import { hrefFor } from "$lib/utils/path";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  const folderPaths = folderPathsForEntries(entries);
  const folderPathSet = new Set(folderPaths);
  const notePaths = entries
    .filter((entry) => pathForDoc(entry) !== "/" && !folderPathSet.has(pathForDoc(entry)))
    .map((entry) => ({ kind: "note" as const, entry, path: pathForDoc(entry) }));

  return [...folderPaths.map((path) => ({ kind: "folder" as const, path })), ...notePaths].map((page) => {
    const slug = page.path.replace(/^\/|\/$/g, "");
    return { params: { slug }, props: { page } };
  });
}

const { page } = Astro.props;
const entries = await getCollection("docs");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const contentIndex = buildContentIndex(entries);
const folder = page.kind === "folder" ? folderListingForPath(entries, page.path) : undefined;
const entry = page.kind === "note" ? page.entry : folder?.entry;
const rendered = entry ? await render(entry) : undefined;
const Content = rendered?.Content;
const headings = rendered?.headings ?? [];
const pageTitle = page.kind === "folder" ? (entry?.data.title ?? folder?.label ?? "Folder") : page.entry.data.title;
const pageDescription = entry?.data.description;
const noteUpdated = page.kind === "note" ? gitUpdatedDateForDoc(page.entry) : undefined;
const currentNotePath = page.kind === "note" ? pathForDoc(page.entry) : undefined;
const sameFolder = currentNotePath ? sameFolderNotes(contentIndex, currentNotePath, 5) : [];
const latest = latestNotes(contentIndex, 5, currentNotePath);
const backlinks = currentNotePath ? backlinkNotes(contentIndex, currentNotePath) : [];
const outbound = currentNotePath ? outboundLinkNotes(contentIndex, currentNotePath) : [];
const folderRecent =
  folder?.notes.toSorted((a, b) => b.updated.getTime() - a.updated.getTime() || a.entry.data.title.localeCompare(b.entry.data.title)).slice(0, 6) ??
  [];
const previews = previewPayload(contentIndex);
const previewJson = JSON.stringify(previews).replace(/</g, "\\u003c");
const hasRightRail = headings.length > 0 || sameFolder.length > 0 || latest.length > 0 || backlinks.length > 0 || outbound.length > 0;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <header class="content-header">
    <h1>{pageTitle}</h1>
    {pageDescription && <p>{pageDescription}</p>}
    {page.kind === "note" && noteUpdated && <NoteMeta entry={page.entry} updated={noteUpdated} base={base} />}
  </header>

  {Content && <Content />}

  {
    folder && (
      <section class:list={["folder-page", Content && "has-intro"]} aria-labelledby="folder-listing-heading">
        {folder.folders.length > 0 && (
          <section class="folder-paths" aria-labelledby="folder-paths-heading">
            <h2 id="folder-paths-heading">Paths</h2>
            <ol class="folder-list">
              {folder.folders.map((child) => (
                <li>
                  <a href={hrefFor(base, child.path)}>{child.label}</a>
                </li>
              ))}
            </ol>
          </section>
        )}

        <div class="folder-board">
          <section class="folder-notes" aria-labelledby="folder-listing-heading">
            <h2 id="folder-listing-heading">Notes</h2>
            {folder.notes.length > 0 ? <NoteList notes={folder.notes} base={base} /> : <p>No notes yet.</p>}
          </section>

          {folderRecent.length > 0 && (
            <aside class="folder-recent" aria-labelledby="folder-recent-heading">
              <h2 id="folder-recent-heading">Recently tended</h2>
              <RightRailNoteList notes={folderRecent} base={base} />
            </aside>
          )}
        </div>
      </section>
    )
  }

  {
    hasRightRail && (
      <div slot="right-rail">
        {page.kind === "note" && (backlinks.length > 0 || outbound.length > 0) && (
          <RightRailSection title="Local map">
            <div class="connection-map" aria-label="Local note map">
              <div>
                <span>In</span>
                <strong>{backlinks.length}</strong>
              </div>
              <div class="connection-map__node">
                <span>{pageTitle}</span>
              </div>
              <div>
                <span>Out</span>
                <strong>{outbound.length}</strong>
              </div>
            </div>
          </RightRailSection>
        )}

        {backlinks.length > 0 && (
          <RightRailSection title="Linked from">
            <RightRailNoteList notes={backlinks} base={base} />
          </RightRailSection>
        )}

        {outbound.length > 0 && (
          <RightRailSection title="Links to">
            <RightRailNoteList notes={outbound} base={base} />
          </RightRailSection>
        )}

        {sameFolder.length > 0 && (
          <RightRailSection title="Same folder">
            <RightRailNoteList notes={sameFolder} base={base} />
          </RightRailSection>
        )}

        {latest.length > 0 && (
          <RightRailSection title="Latest">
            <RightRailNoteList notes={latest} base={base} />
          </RightRailSection>
        )}

        {headings.length > 0 && (
          <RightRailSection title="On this page">
            <nav class="page-toc" aria-label="Page table of contents">
              <ol>
                {headings
                  .filter((heading) => heading.depth === 2 || heading.depth === 3)
                  .map((heading) => (
                    <li class={`depth-${heading.depth}`}>
                      <a href={`#${heading.slug}`}>{heading.text}</a>
                    </li>
                  ))}
              </ol>
            </nav>
          </RightRailSection>
        )}
      </div>
    )
  }

  {page.kind === "note" && <script is:inline type="application/json" id="note-preview-data" set:html={previewJson} />}

  {
    page.kind === "note" && (
      <script is:inline>
        const previewData = JSON.parse(document.getElementById("note-preview-data")?.textContent ?? "{}");
        const basePath = document.documentElement.dataset.basePath ?? "";
        const content = document.querySelector(".content");
        const previewCard = document.createElement("div");
        previewCard.className = "note-preview";
        previewCard.innerHTML = `<strong></strong><small></small><span></span>`;
        document.body.append(previewCard);

        function normalizePreviewPath(href) {
          const url = new URL(href, window.location.href);
          if (url.origin !== window.location.origin) return undefined;
          if (basePath && !url.pathname.startsWith(`${basePath}/`)) return undefined;
          const path = basePath ? url.pathname.slice(basePath.length) : url.pathname;
          return path.endsWith("/") ? path : `${path}/`;
        }

        function hidePreview() {
          previewCard.classList.remove("is-visible");
        }

        function showPreview(link, preview) {
          previewCard.querySelector("strong").textContent = preview.title;
          previewCard.querySelector("small").textContent = [preview.date, ...(preview.tags ?? [])].filter(Boolean).join(" · ");
          previewCard.querySelector("span").textContent = preview.excerpt;
          previewCard.classList.add("is-visible");

          const linkRect = link.getBoundingClientRect();
          const cardRect = previewCard.getBoundingClientRect();
          const gap = 8;
          const left = Math.min(Math.max(gap, linkRect.left), window.innerWidth - cardRect.width - gap);
          const bottomTop = linkRect.bottom + gap;
          const top =
            bottomTop + cardRect.height <= window.innerHeight - gap
              ? bottomTop
              : Math.max(gap, linkRect.top - cardRect.height - gap);

          previewCard.style.left = `${left}px`;
          previewCard.style.top = `${top}px`;
        }

        content?.querySelectorAll("a[href]").forEach((link) => {
          const path = normalizePreviewPath(link.href);
          const preview = path ? previewData[path] : undefined;
          if (!preview) return;

          link.classList.add("has-note-preview");
          link.addEventListener("mouseenter", () => showPreview(link, preview));
          link.addEventListener("focus", () => showPreview(link, preview));
          link.addEventListener("mouseleave", hidePreview);
          link.addEventListener("blur", hidePreview);
        });

        window.addEventListener("scroll", hidePreview, true);
        window.addEventListener("resize", hidePreview);
        window.addEventListener("keydown", (event) => {
          if (event.key === "Escape") hidePreview();
        });
      </script>
    )
  }

  <style>
    :global(.content:has(.folder-page)) {
      max-width: 72rem;
    }

    .connection-map {
      align-items: center;
      display: grid;
      gap: 0.5rem;
      grid-template-columns: minmax(0, 1fr) minmax(5rem, 1.35fr) minmax(0, 1fr);
    }

    .connection-map > div {
      background: color-mix(in srgb, var(--color-surface) 70%, transparent);
      border: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
      border-radius: 0.45rem;
      min-width: 0;
      padding: 0.55rem;
      text-align: center;
    }

    .connection-map span {
      color: var(--color-muted);
      display: block;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      line-height: 1.2;
      overflow: hidden;
      text-overflow: ellipsis;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .connection-map strong {
      color: var(--color-text);
      display: block;
      font-size: 1.1rem;
      line-height: 1.2;
      margin-top: 0.25rem;
    }

    .connection-map__node {
      border-color: var(--color-accent);
    }

    .connection-map__node span {
      color: var(--color-text);
      font-family: var(--font-heading);
      font-size: 0.82rem;
      text-transform: none;
    }

    .folder-page {
      margin-top: 0;
    }

    .folder-page.has-intro {
      border-top: 1px solid var(--color-border);
      margin-top: 2.25rem;
      padding-top: 2rem;
    }

    .folder-page h2,
    .folder-board h2 {
      font-family: var(--font-heading);
      margin: 0 0 1rem;
    }

    .folder-paths {
      margin-bottom: 2rem;
    }

    .folder-list {
      display: grid;
      gap: 0.65rem;
      grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
      list-style: none;
      margin: 0 0 1.5rem;
      padding: 0;
    }

    .folder-list a {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      color: var(--color-text);
      display: block;
      font-weight: 650;
      padding: 0.75rem 0.85rem;
      text-decoration: none;
    }

    .folder-list a:hover,
    .folder-list a:focus-visible {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }

    .folder-list a:focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: 3px;
    }

    .folder-board {
      align-items: start;
      display: grid;
      gap: clamp(1.5rem, 4vw, 2.5rem);
      grid-template-columns: minmax(0, 1fr) minmax(14rem, 18rem);
    }

    .folder-notes,
    .folder-recent {
      min-width: 0;
    }

    .folder-recent {
      border-left: 1px solid var(--color-border);
      padding-left: 1.25rem;
    }

    @media (max-width: 860px) {
      .folder-board {
        display: block;
      }

      .folder-recent {
        border-left: 0;
        border-top: 1px solid var(--color-border);
        margin-top: 2rem;
        padding-left: 0;
        padding-top: 1.5rem;
      }
    }
  </style>
</BaseLayout>
