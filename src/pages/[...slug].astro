---
import { getCollection, render } from "astro:content";
import NoteList from "$components/NoteList.astro";
import BaseLayout from "$layouts/BaseLayout.astro";
import { pathForDoc } from "$lib/content/paths";
import { folderListingForPath, folderPathsForEntries } from "$lib/content/tree";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  const folderPaths = folderPathsForEntries(entries);
  const folderPathSet = new Set(folderPaths);
  const notePaths = entries
    .filter((entry) => pathForDoc(entry) !== "/" && !folderPathSet.has(pathForDoc(entry)))
    .map((entry) => ({ kind: "note" as const, entry, path: pathForDoc(entry) }));

  return [...folderPaths.map((path) => ({ kind: "folder" as const, path })), ...notePaths].map((page) => {
    const slug = page.path.replace(/^\/|\/$/g, "");
    return { params: { slug }, props: { page } };
  });
}

const { page } = Astro.props;
const entries = await getCollection("docs");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const hrefFor = (path: string) => `${base}${path}` || "/";
const folder = page.kind === "folder" ? folderListingForPath(entries, page.path) : undefined;
const entry = page.kind === "note" ? page.entry : folder?.entry;
const rendered = entry ? await render(entry) : undefined;
const Content = rendered?.Content;
const headings = rendered?.headings ?? [];
const pageTitle = page.kind === "folder" ? (entry?.data.title ?? folder?.label ?? "Folder") : page.entry.data.title;
const pageDescription = entry?.data.description;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <header class="content-header">
    <h1>{pageTitle}</h1>
    {pageDescription && <p>{pageDescription}</p>}
  </header>

  {Content && <Content />}

  {
    folder && (
      <section class:list={["folder-page", Content && "has-intro"]} aria-labelledby="folder-listing-heading">
        <h2 id="folder-listing-heading">Browse</h2>

        {folder.folders.length > 0 && (
          <ol class="folder-list">
            {folder.folders.map((child) => (
              <li>
                <a href={hrefFor(child.path)}>{child.label}</a>
              </li>
            ))}
          </ol>
        )}

        {folder.notes.length > 0 ? <NoteList notes={folder.notes} base={base} /> : <p>No notes yet.</p>}
      </section>
    )
  }

  {
    headings.length > 0 && (
      <div slot="right-rail">
        <nav class="page-toc" aria-label="Page table of contents">
          <h2>On this page</h2>
          <ol>
            {headings
              .filter((heading) => heading.depth === 2 || heading.depth === 3)
              .map((heading) => (
                <li class={`depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
          </ol>
        </nav>
      </div>
    )
  }

  <style>
    .folder-page {
      margin-top: 0;
    }

    .folder-page.has-intro {
      margin-top: 2rem;
    }

    .folder-page h2 {
      font-family: var(--font-heading);
      margin: 0 0 1rem;
    }

    .folder-list {
      display: grid;
      gap: 0.5rem;
      grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
      list-style: none;
      margin: 0 0 1.5rem;
      padding: 0;
    }

    .folder-list a {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 0.5rem;
      color: var(--color-text);
      display: block;
      font-weight: 650;
      padding: 0.75rem 0.85rem;
      text-decoration: none;
    }

    .folder-list a:hover,
    .folder-list a:focus-visible {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }

    .folder-list a:focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: 3px;
    }
  </style>
</BaseLayout>
