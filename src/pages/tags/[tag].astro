---
import { getCollection } from "astro:content";
import NoteList from "$components/NoteList.astro";
import BaseLayout from "$layouts/BaseLayout.astro";
import { gitUpdatedDateForDoc } from "$lib/content/dates";
import { pathForDoc } from "$lib/content/paths";
import { tagSlug, tagTitle, tagsForDoc } from "$lib/tags";
import { hrefFor } from "$lib/utils/path";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  const tagSlugs = new Set(
    entries
      .filter((entry) => pathForDoc(entry) !== "/" && entry.data.sidebar?.hidden !== true)
      .flatMap((entry) => tagsForDoc(entry).map(tagSlug)),
  );

  return [...tagSlugs].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

if (!tag) {
  throw new Error("Missing tag route parameter");
}

const entries = await getCollection("docs");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const title = tagTitle(tag);
const notes = entries
  .filter((entry) => pathForDoc(entry) !== "/" && entry.data.sidebar?.hidden !== true)
  .filter((entry) => tagsForDoc(entry).map(tagSlug).includes(tag))
  .map((entry) => ({ entry, path: pathForDoc(entry), updated: gitUpdatedDateForDoc(entry) }))
  .sort((a, b) => b.updated.getTime() - a.updated.getTime() || a.entry.data.title.localeCompare(b.entry.data.title));
---

<BaseLayout title={`Tag: ${title}`} description={`Notes tagged ${title}.`}>
  <header class="content-header">
    <p><a href={hrefFor(base, "/tags/")}>Tags</a></p>
    <h1>{title}</h1>
    <p>{notes.length} {notes.length === 1 ? "note" : "notes"}</p>
  </header>

  <NoteList notes={notes} base={base} />
</BaseLayout>
